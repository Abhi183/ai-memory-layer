# ── AI Memory Layer — Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in the values.

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-32-byte-random-string-in-production

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://memuser:mempass@localhost:5432/aimemory

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# ── LLM Provider Keys ─────────────────────────────────────────────────────────
# Used for fact extraction, summarization, and classification in the pipeline.
# At least one provider is required for memory processing.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Embedding Model ───────────────────────────────────────────────────────────
# Options: openai (default, requires OPENAI_API_KEY) | local (no key needed)
USE_LOCAL_EMBEDDINGS=false
# LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Memory Pipeline Settings ──────────────────────────────────────────────────
# Tokens assumed for a full conversation history (used for compression ratio)
FULL_CONTEXT_BASELINE_TOKENS=15000
SIMILARITY_THRESHOLD=0.65
MAX_CONTEXT_MEMORIES=5
